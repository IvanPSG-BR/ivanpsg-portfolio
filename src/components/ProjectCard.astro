---
/**
 * ProjectCard Component - Card individual de projeto
 *
 * Props:
 * - title: Título do projeto
 * - description: Descrição breve
 * - stack: Array de tecnologias (strings)
 * - link: URL do projeto/repo
 * - thumbnail: URL da imagem (opcional)
 */

interface Props {
  title: string;
  description: string;
  stack: string[];
  link: string;
  thumbnail?: string;
}

const { title, description, stack, link, thumbnail } = Astro.props;
---

<article class="card group">
  <!-- Thumbnail circular (opcional) -->
  {
    thumbnail && (
      <div class="mb-4">
        <div class="w-12 h-12 rounded-full bg-modern-accent/10 border border-modern-accent flex items-center justify-center overflow-hidden">
          <img
            src={thumbnail}
            alt={`Logo do projeto ${title}`}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    )
  }

  <!-- Título do projeto -->
  <h3
    class="text-xl md:text-2xl font-mono font-bold text-modern-text mb-3 group-hover:text-modern-accent transition-colors duration-240"
  >
    {title}
  </h3>

  <!-- Descrição -->
  <p class="text-modern-muted mb-6 leading-relaxed">
    {description}
  </p>

  <!-- Link para o projeto -->
  <a
    href={link}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 text-modern-accent hover:text-modern-accent2 transition-colors duration-240 font-medium"
    aria-label={`Ver projeto ${title} (abre em nova aba)`}
  >
    Ver projeto
    <svg
      class="w-4 h-4 transition-transform duration-240 group-hover:translate-x-1"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
    </svg>
  </a>
</article>
